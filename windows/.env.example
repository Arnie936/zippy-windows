# Required for the main screenshot + vision assistant flow
ANTHROPIC_API_KEY=sk-ant-...

# Required for ElevenLabs speech-to-text and text-to-speech
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# Optional: choose speech-to-text provider: elevenlabs or whisper
STT_PROVIDER=elevenlabs

# Optional: local Codex one-shot handoff
CODEX_COMMAND=codex.cmd
CLAUDE_CODE_COMMAND=claude
CODEX_WORKDIR=..\\playground
CODEX_TIMEOUT_SECONDS=900
OPENCLAW_COMMAND=openclaw
OPENCLAW_SESSION_KEY=main
OPENCLAW_TIMEOUT_SECONDS=120

# Optional: local Whisper fallback
WHISPER_PYTHON=python
WHISPER_MODEL=base
WHISPER_LANGUAGE=de

# Optional: global push-to-talk hotkey
PUSH_TO_TALK_KEY=F8
